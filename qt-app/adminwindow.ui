        <bold>true</bold>
       </font>
      </property>
      <property name="styleSheet">
       <string notr="true">/* 🌟 Floating Total Visitors Label */
QLabel#visitorTotalLabel {
    background-color: #F8F9FA;       /* Light gray background */
    border: 1px solid #D0D7DE;       /* Soft gray border */
    border-radius: 8px;              /* Rounded corners */
    padding: 6px 12px;               /* Inner spacing */
    color: #2C3E50;                  /* Dark gray text */
    font-weight: bold;
    font-size: 10pt;
    qproperty-alignment: 'AlignCenter'; /* Center text inside label */
    min-width: 180px;
    min-height: 30px;
}

/* 💫 Optional hover or focus effect (just for polish) */
QLabel#visitorTotalLabel:hover {
    background-color: #E9F5FF;       /* Slight blue tint on hover */
    border: 1px solid #B3D8FF;
}

/* 🩶 Optional subtle shadow illusion (via border and gradient trick) */
QLabel#visitorTotalLabel {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #FFFFFF,
        stop:1 #F0F0F0
    );
}
</string>
      </property>
