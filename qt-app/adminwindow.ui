    <widget class="QWidget" name="reportingPage">
     <property name="styleSheet">
      <string notr="true">/* === REPORTING PAGE BACKGROUND === */
QWidget#reportingPage {
    background-color: #F7F9FB;
    border: none;
}

/* === LABELS === */
QLabel {
    color: #2C3E50;
    font-size: 11pt;
    font-weight: 600;
}

/* === COMBO BOXES === */
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #BDC3C7;
    border-radius: 6px;
    padding: 4px 8px;
    color: #2C3E50;
}
QComboBox:hover {
    border: 1px solid #4A90E2;
}
QComboBox:focus {
    background-color: #FFFFFF;
    border: 1px solid #4A90E2;
}

/* === DATE EDITS === */
QDateEdit {
    background-color: #FFFFFF;
    border: 1px solid #BDC3C7;
    border-radius: 6px;
    padding: 4px 8px;
    color: #2C3E50;
}
QDateEdit:hover {
    border: 1px solid #4A90E2;
}
QDateEdit:focus {
    background-color: #FFFFFF;
    border: 1px solid #4A90E2;
}

/* === PUSH BUTTONS === */
QPushButton {
    background-color: #4A90E2;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #357ABD;
}
QPushButton:pressed {
    background-color: #2D5C9F;
}
QPushButton:disabled {
    background-color: #D6E4F0;
    color: #A0A0A0;
}

/* === FRAMES === */
QFrame {
    background-color: #FFFFFF;
    border-radius: 10px;
    border: 1px solid #E0E0E0;
}

/* === TABLES === */
QTableWidget {
    background-color: #FFFFFF;
    gridline-color: #E0E0E0;
    border: 1px solid #DADADA;
    border-radius: 8px;
    selection-background-color: #E8F2FF;
    selection-color: #1E3A5F;
    alternate-background-color: #FAFAFA;
}
QHeaderView::section {
    background-color: #EDF2F7;
    color: #2C3E50;
    padding: 6px;
    border: 1px solid #DADADA;
    font-weight: bold;
}

/* === SCROLLBARS === */
QScrollBar:vertical {
    border: none;
    background: #F0F2F5;
    width: 10px;
}
QScrollBar::handle:vertical {
    background: #BDC3C7;
    border-radius: 5px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background: #A0A6AA;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
</string>
