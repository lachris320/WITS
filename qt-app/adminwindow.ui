  <property name="styleSheet">
   <string notr="true">/* --- Global / root --- */
QWidget {
  background: #F6F8FA;
  color: #2C3E50;
  font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
  font-size: 12px;
}

/* --- Sidebar --- */
QFrame#sidebarFrame {
  background-color: #2B2F3A;
}

/* --- Card frames: bulk, register, start semester --- */
QFrame#leftFrameBulk, QFrame#rightFrameRegister, QFrame#databaseFrame,
QGroupBox { 
  background: #FFFFFF;
  border-radius: 10px;
  border: 1px solid #E6EEF4;
  padding: 10px;
}

/* --- Titles --- */
QLabel#sectionTitle, QLabel.groupTitle {
  font-size: 15px;
  font-weight: 600;
  color: #34495E;
}

/* --- Buttons --- */
QPushButton {
  background-color: #F5F7FA;
  border: 1px solid #D6DCE3;
  padding: 6px 10px;
  border-radius: 8px;
}
QPushButton:hover { background: #EAF3FF; }
QPushButton:pressed { background: #DCEFFE; }

/* special database buttons */
QPushButton#attachFileBtn { background:#27AE60; color: white; font-weight: 600; }
QPushButton#updateDatabaseBtn { background:#E67E22; color: white; font-weight: 600; }

/* --- Line edits / combos --- */
QLineEdit, QComboBox, QSpinBox, QDateEdit {
  background: #FBFCFD;
  border: 1px solid #DCE4EA;
  border-radius: 6px;
  padding: 6px;
}
QLineEdit:focus, QComboBox:focus { border: 1px solid #4A90E2; }

/* --- Table --- */
QTableWidget {
  background: #FFFFFF;
  border: 1px solid #E6EEF4;
  border-radius: 8px;
  gridline-color: #F1F5F8;
}
QTableWidget::item:selected { background: #4A90E2; color: white; }
QHeaderView::section {
  background: #F2F4F8;
  color: #2C3E50;
  padding: 6px;
  border: 1px solid #E0E6EB;
  font-weight: 600;
}

/* --- Photo preview --- */
QLabel#studentPhotoLabel {
  background: #FAFAFA;
  border: 1px dashed #D0D7DE;
  min-width: 140px;
  min-height: 160px;
  qproperty-alignment: AlignCenter;
  border-radius: 8px;
}

/* --- Floating total badge (visitor total) --- */
QLabel#visitorTotalLabel {
  background: rgba(255,255,255,0.96);
  color: #2C3E50;
  padding: 6px 10px;
  border-radius: 10px;
  border: 1px solid rgba(0,0,0,0.06);
  font-weight: 600;
}

/* --- Progress bar --- */
QProgressBar {
  background: #F0F2F5;
  border-radius: 4px;
  height: 8px;
}
QProgressBar::chunk {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
            stop:0 #5AA9FF, stop:1 #1781E8);
  border-radius: 4px;
}
</string>
